                    "rel": "evidence",
                    "text": "Signed evidence bundle"
                  }
                ]
              },
              {
                "uuid": "0ad28f7b-666b-4720-9e16-1c630719a117",
                "control-id": "164.308(a)(7)",
                "description": "Contingency plan — S3 versioning enabled on the uploads bucket (GAP-04) makes PHI overwrites recoverable. The evidence vault bucket also has versioning and Object Lock (GOVERNANCE mode, 365-day retention) to preserve audit artefacts.",
                "props": [
                  {
                    "name": "terraform-resource",
                    "value": "aws_s3_bucket_versioning.uploads"
                  },
                  {
                    "name": "terraform-resource",
                    "value": "aws_s3_bucket_object_lock_configuration.evidence"
                  },
                  {
                    "name": "policy",
                    "value": "policies/s3_versioning.rego"
                  },
                  {
                    "name": "gap-closed",
                    "value": "GAP-04"
                  },
