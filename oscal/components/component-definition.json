              },
              {
                "uuid": "9bf7e505-7041-4755-bc76-41b83d505d18",
                "control-id": "164.312(e)(1)",
                "description": "Transmission security — S3 uploads bucket has an aws_s3_bucket_policy denying requests where aws:SecureTransport is false (GAP-03). Lambda is placed inside the VPC private subnets with a hardened security group (GAP-05). VPC Gateway endpoints for S3 and DynamoDB prevent traffic from leaving the VPC.",
                "props": [
                  {
                    "name": "terraform-resource",
                    "value": "aws_s3_bucket_policy.uploads_tls_only"
                  },
                  {
                    "name": "terraform-resource",
                    "value": "aws_security_group.lambda"
                  },
                  {
                    "name": "terraform-resource",
                    "value": "aws_vpc_endpoint.dynamodb"
                  },
                  {
                    "name": "terraform-resource",
                    "value": "aws_vpc_endpoint.s3"
                  },
                  {
                    "name": "terraform-resource",
                    "value": "aws_lambda_function.intake (vpc_config override)"
                  },
                  {
                    "name": "policy",
                    "value": "policies/s3_tls_required.rego"
                  },
                  {
                    "name": "policy",
                    "value": "policies/lambda_vpc.rego"
                  },
                  {
                    "name": "gap-closed",
                    "value": "GAP-03"
                  },
                  {
                    "name": "gap-closed",
                    "value": "GAP-05"
                  },
