                ],
                "links": [
                  {
                    "href": "s3://REPLACE_WITH_EVIDENCE_BUCKET/runs/latest/evidence-bundle.tar.gz",
                    "rel": "evidence",
                    "text": "Signed evidence bundle"
                  }
                ]
              },
              {
