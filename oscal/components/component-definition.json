                "control-id": "164.312(a)(2)(iv)",
                "description": "Encryption and decryption — S3 uploads bucket and DynamoDB submissions table are encrypted with a customer-managed KMS key (aws_kms_key.phi). The CMK has key rotation enabled. This closes GAP-01 and GAP-02.",
                "props": [
                  {
                    "name": "terraform-resource",
                    "value": "aws_kms_key.phi"
                  },
                  {
                    "name": "terraform-resource",
                    "value": "aws_s3_bucket_server_side_encryption_configuration.uploads"
                  },
                  {
                    "name": "terraform-resource",
                    "value": "aws_dynamodb_table.intake (server_side_encryption override)"
                  },
                  {
                    "name": "policy",
                    "value": "policies/s3_cmk_encryption.rego"
                  },
                  {
                    "name": "policy",
                    "value": "policies/dynamodb_cmk.rego"
                  },
                  {
                    "name": "gap-closed",
                    "value": "GAP-01"
                  },
                  {
                    "name": "gap-closed",
                    "value": "GAP-02"
                  },
                  {
                    "name": "soc2-crossref",
                    "value": "CC6.1"
                  },
                  {
                    "name": "cmmc-crossref",
                    "value": "SC.L2-3.13.11"
                  }
